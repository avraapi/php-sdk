{
    "name": "avraapi/apix-php-sdk",
    "description": "Official PHP SDK for the APIX (AvraAPI) enterprise API gateway. Zero Laravel dependencies — works in any PHP 8.2+ project.",
    "version": "1.0.0",
    "type": "library",
    "keywords": ["apix", "avraapi", "sms", "pdf", "qr", "barcode", "sdk", "api-gateway"],
    "license": "MIT",
    "authors": [
        {
            "name": "Fidex Developers (Pvt) Ltd",
            "email": "dev@fidex.lk",
            "homepage": "https://avraapi.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8",
        "guzzlehttp/promises": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Avraapi\\Apix\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Avraapi\\Apix\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
